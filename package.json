{
  "name": "workbench-inventory",
  "version": "0.0.1",
  "private": true,
  "description": "Workbench Inventory — NestJS API + React kiosk (see PLAN.md)",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "build": "nest build && npm run build --workspace frontend",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest && npm run test --workspace frontend",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json && npm run typecheck --workspace frontend"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "better-sqlite3": "^11.0.0",
    "bwip-js": "^4.5.0",
    "canvas": "^3.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.0",
    "source-map-support": "^0.5.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
